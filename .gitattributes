# Normalização de line-endings em todos os textos.
* text=auto eol=lf

# Scripts Windows mantêm CRLF nativo.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binários não devem ser tocados.
*.wav binary
*.mp3 binary
*.ogg binary
*.flac binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
